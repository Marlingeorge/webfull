<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="1200" viewBox="0 0 1200 1200">
  <defs>
    <linearGradient id="g" x1="0" x2="1" y1="0" y2="1">
      <stop offset="0%" stop-color="#e6f9ee"/>
      <stop offset="100%" stop-color="#bff0c8"/>
    </linearGradient>
    <style>
      .title { font: 48px/1.2 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif; fill:#23401f }
      .sub { font: 20px 'Inter', sans-serif; fill:#2d5530 }
    </style>
  </defs>
  <rect width="100%" height="100%" fill="url(#g)" rx="40"/>
  <g transform="translate(600,420)" text-anchor="middle">
    <circle r="220" fill="#ffffff" opacity="0.08"/>
    <text class="title" y="-10">Propo</text>
    <text class="sub" y="40">(placeholder)</text>
  </g>
</svg>
